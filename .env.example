# Copie para .env e preencha com os valores do seu projeto Supabase
# Painel Supabase → Project Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# Deixe desligado (ou remova) enquanto o Stripe não estiver ligado.
# Quando quiser exigir assinatura para usar o app, defina como true.
VITE_REQUIRE_SUBSCRIPTION=false
